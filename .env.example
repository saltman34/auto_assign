# Copy to `.env` in the project root (same directory as `pyproject.toml`).
# The app and Alembic both load `.env` via `auto_assign.db.session`.
# Do not commit real credentials.

# --- Option A (recommended): single URL ---
# Use the psycopg v3 driver scheme:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/DATABASE_NAME
#
# Bare `postgresql://` is rewritten to `postgresql+psycopg://` automatically.

# --- Option B: discrete variables ---
# POSTGRES_USER=myuser
# POSTGRES_PASSWORD=
# POSTGRES_DB=auto_assign
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Note: python-dotenv does not expand `${VAR}` in values. Use Option A or literal strings.
